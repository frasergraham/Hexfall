# CloudKit Web Services API token used by the web build to read the
# public corpus of community challenges (browse / leaderboard / install).
#
# Create the token in CloudKit Console:
#   icloud.developer.apple.com → iCloud.com.hexrain.app →
#   Tokens & Keys → API Tokens → +
# Pick the environment, grant Query Records permission only, save.
#
# Copy this file to `.env.local` (gitignored) and paste the token below.
# Without it, the Community Challenges section on the web build shows
# the "UNAVAILABLE" placeholder.
VITE_CLOUDKIT_API_TOKEN=

# Which CloudKit environment to read from. Default "development".
# Switch to "production" once the schema has been promoted via
# `xcrun cktool import-schema --environment production` and the iOS
# App Store build is live.
VITE_CLOUDKIT_ENV=development
